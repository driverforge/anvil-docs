# URL of the Anvil app, used by the docs API-key feature to call
# `/api/docs/projects` with credentials.
#
# Local dev (Caddy on *.driverforge.test): https://app.driverforge.test
# Production: baked in at Docker build time via an ARG in the Dockerfile.
APP_URL=https://app.driverforge.test

# GA4 via Google tag gateway. Leave empty in local dev — the
# /gt path only exists behind the Cloudflare proxy in production.
# (Docker builds derive this from the NEXT_PUBLIC_GA_MEASUREMENT_ID ARG.)
GA_MEASUREMENT_ID=
